<Window x:Class="ChatClientWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Клієнт чату" Height="450" Width="800">
    <Grid>
        <ComboBox x:Name="ChatModeComboBox" HorizontalAlignment="Left" Margin="207,32,0,0" VerticalAlignment="Top" Width="120" SelectedIndex="0">
            <ComboBoxItem Content="Людина"/>
            <ComboBoxItem Content="Робот"/>
        </ComboBox>
        <TextBlock HorizontalAlignment="Left" Margin="40,32,0,0" Text="Режим клієнта:" FontSize="16" VerticalAlignment="Top"/>
        
        <TextBlock HorizontalAlignment="Left" Margin="40,75,0,0" Text="IP:" FontSize="16" VerticalAlignment="Top"/>
        <TextBox x:Name="IpInput" HorizontalAlignment="Left" Margin="75,70,0,0" VerticalAlignment="Top" Width="120" Height="30" Text="127.0.0.1" FontSize="16"/>
        
        <TextBlock HorizontalAlignment="Left" Margin="210,75,0,0" Text="Порт:" FontSize="16" VerticalAlignment="Top"/>
        <TextBox x:Name="PortInput" HorizontalAlignment="Left" Margin="265,70,0,0" VerticalAlignment="Top" Width="80" Height="30" Text="11000" FontSize="16"/>
        
        <TextBox x:Name="ChatDisplay" HorizontalAlignment="Left" Margin="40,120,0,0" VerticalAlignment="Top" Width="405" Height="280" FontSize="16" IsReadOnly="True" VerticalScrollBarVisibility="Auto"/>
        
        <Button Content="Приєднатися" HorizontalAlignment="Left" Margin="360,70,0,0" VerticalAlignment="Top" Height="30" Width="100" Click="connectToServer"/>
        
        <TextBox x:Name="MessageInput" HorizontalAlignment="Left" Margin="484,200,0,0" VerticalAlignment="Top" Width="270" Height="100" FontSize="16" TextWrapping="Wrap"/>
        <Button Content="Надіслати" HorizontalAlignment="Left" Margin="484,310,0,0" VerticalAlignment="Top" Height="40" Width="270" Click="sendMessage"/>
    </Grid>
</Window>